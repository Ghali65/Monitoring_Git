{"data": {"args": [], "base_msg": "On list__gold: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.8\", \"profile_name\": \"clickhouse_profile\", \"target_name\": \"dev\", \"connection_name\": \"list__gold\"} */\nwith mv_sources as (\n      -- Find all MVs and their target tables (database and name of the MV, plus the SELECT SQL)\n      select\n        name as mv_name,\n        database as mv_database,\n        any(as_select) as mv_sql,\n        any(replaceRegexpOne(create_table_query, '.*TO\\\\s+`?([^`\\\\s(]+)`?\\\\.`?([^`\\\\s(]+)`?.*', '\\\\1.\\\\2')) as target_fqn\n      \n      from system.tables\n      \n      where engine = 'MaterializedView'\n        and create_table_query like '%TO %'\n      group by mv_name, mv_database\n    )\n    select\n      t.name as name,\n      t.database as schema,\n      multiIf(\n        t.engine = 'MaterializedView', 'materialized_view',\n        t.engine = 'View', 'view',\n        t.engine = 'Dictionary', 'dictionary',\n        'table'\n      ) as type,\n      db.engine as db_engine,\n      groupArrayIf(\n        map('schema', mv_sources.mv_database, 'name', mv_sources.mv_name, 'sql', mv_sources.mv_sql),\n        mv_sources.mv_name != ''\n      ) as mvs_pointing_to_it,0 as is_on_cluster\n        from system.tables as t\n      \n        join system.databases as db on t.database = db.name\n        left join mv_sources on mv_sources.target_fqn = concat(t.database, '.', t.name)\n      where schema = 'gold'\n      group by name, schema, type, db_engine\n\n  ...", "name": "dbt_clickhouse"}, "info": {"category": "", "code": "E001", "extra": {}, "invocation_id": "21025d5d-9713-43e5-ba2a-da72a818dfdc", "level": "debug", "msg": "dbt_clickhouse adapter: On list__gold: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.8\", \"profile_name\": \"clickhouse_profile\", \"target_name\": \"dev\", \"connection_name\": \"list__gold\"} */\nwith mv_sources as (\n      -- Find all MVs and their target tables (database and name of the MV, plus the SELECT SQL)\n      select\n        name as mv_name,\n        database as mv_database,\n        any(as_select) as mv_sql,\n        any(replaceRegexpOne(create_table_query, '.*TO\\\\s+`?([^`\\\\s(]+)`?\\\\.`?([^`\\\\s(]+)`?.*', '\\\\1.\\\\2')) as target_fqn\n      \n      from system.tables\n      \n      where engine = 'MaterializedView'\n        and create_table_query like '%TO %'\n      group by mv_name, mv_database\n    )\n    select\n      t.name as name,\n      t.database as schema,\n      multiIf(\n        t.engine = 'MaterializedView', 'materialized_view',\n        t.engine = 'View', 'view',\n        t.engine = 'Dictionary', 'dictionary',\n        'table'\n      ) as type,\n      db.engine as db_engine,\n      groupArrayIf(\n        map('schema', mv_sources.mv_database, 'name', mv_sources.mv_name, 'sql', mv_sources.mv_sql),\n        mv_sources.mv_name != ''\n      ) as mvs_pointing_to_it,0 as is_on_cluster\n        from system.tables as t\n      \n        join system.databases as db on t.database = db.name\n        left join mv_sources on mv_sources.target_fqn = concat(t.database, '.', t.name)\n      where schema = 'gold'\n      group by name, schema, type, db_engine\n\n  ...", "name": "AdapterEventDebug", "pid": 2455, "thread": "ThreadPoolExecutor-1_0", "ts": "2026-05-07T13:48:03.739019Z"}}
