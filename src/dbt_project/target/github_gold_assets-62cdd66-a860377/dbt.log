{"data": {"args": [], "base_msg": "On model.github_deps_gold.fact_vulnerability_scan: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.8\", \"profile_name\": \"clickhouse_profile\", \"target_name\": \"dev\", \"node_id\": \"model.github_deps_gold.fact_vulnerability_scan\"} */\n\n            \n\n    \n        create table `gold`.`fact_vulnerability_scan__dbt_backup`\n        \n  \n        \n  engine = MergeTree()\n        \n      order by (tuple())\n        \n        \n        \n        \n                    -- end_of_sql\n                    SETTINGS replicated_deduplication_window='0'\n\n                    \n            empty\n          as (\n            \n\nSELECT\n    reinterpretAsUInt64(MD5(concat(rel.parent_id, rel.child_id, vuln._dlt_parent_id))) as scan_id,\n    toYYYYMMDD(parseDateTime64BestEffort(rel.detected_at)) as date_id,\n    toUUID(rel.parent_id) as repo_id,\n    toUUID(rel.child_id) as dependency_id,\n    vuln._dlt_parent_id as advisory_id,\n    adv.cvss__score as severity_score,\n    1 as is_vulnerable,\n    if(vuln.first_patched_version IS NOT NULL, 1, 0) as has_patch,\n    parseDateTime64BestEffort(rel.detected_at) as detected_at\nFROM `default`.`silver_dependency_relations` rel\nJOIN `default`.`silver_components` comp ON rel.child_id = toString(comp.id)\nJOIN `default`.`silver_github_advisories_vulnerabilities` vuln \n    ON comp.name = vuln.package__name \n    AND comp.ecosystem = vuln.package__ecosystem\nJOIN `default`.`silver_github_advisories` adv ON vuln._dlt_parent_id = adv._dlt_id\n          )\n        \n        ...", "name": "dbt_clickhouse", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "83c21456bd91b0a653cf15d0e6f4cb14f456f3e69a24a3d7a052ba1da347713a", "node_finished_at": "", "node_name": "fact_vulnerability_scan", "node_path": "gold/fact_vulnerability_scan.sql", "node_relation": {"alias": "fact_vulnerability_scan", "database": "", "relation_name": "`gold`.`fact_vulnerability_scan`", "schema": "gold"}, "node_started_a