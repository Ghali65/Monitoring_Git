{"data": {"args": [], "base_msg": "On model.github_deps_gold.dim_dependency: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.8\", \"profile_name\": \"clickhouse_profile\", \"target_name\": \"dev\", \"node_id\": \"model.github_deps_gold.dim_dependency\"} */\n\n            \n\n    \n        create table `gold`.`dim_dependency__dbt_backup`\n        \n  \n        \n  engine = MergeTree()\n        \n      order by (tuple())\n        \n        \n        \n        \n                    -- end_of_sql\n                    SETTINGS replicated_deduplication_window='0'\n\n                    \n            empty\n          as (\n            \n\nSELECT DISTINCT\n    c.id as dependency_id,\n    c.name,\n    rel.version,\n    c.purl\nFROM `default`.`silver_components` c\nJOIN `default`.`silver_dependency_relations` rel ON toString(c.id) = rel.child_id\n          )\n        \n        ...", "name": "dbt_clickhouse", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "f6011a5ce692303e0ae84d1fe8eb8b2e20be42db9eb861cc0fac8485a05d7ddc", "node_finished_at": "", "node_name": "dim_dependency", "node_path": "gold/dim_dependency.sql", "node_relation": {"alias": "dim_dependency", "database": "", "relation_name": "`gold`.`dim_dependency`", "schema": "gold"}, "node_started_at": "2026-05-07T13:48:03.831847", "node_status": "executing", "resource_type": "model", "unique_id": "model.github_deps_gold.dim_dependency"}}, "info": {"category": "", "code": "E001", "extra": {}, "invocation_id": "21025d5d-9713-43e5-ba2a-da72a818dfdc", "level": "debug", "msg": "dbt_clickhouse adapter: On model.github_deps_gold.dim_dependency: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.8\", \"profile_name\": \"clickhouse_profile\", \"target_name\": \"dev\", \"node_id\": \"model.github_deps_gold.dim_dependency\"} */\n\n            \n\n    \n        create table `gold`.`dim_dependency__dbt_backup`\n        \n  \n        \n  engine = MergeTree()\n        \n      order by (tuple())\n        \n        \n        